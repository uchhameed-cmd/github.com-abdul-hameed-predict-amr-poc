# %% [markdown]
# # PREDICT-AMR: Exploratory Data Analysis
# 
# This notebook explores the PATRIC AMR dataset to understand data distribution and guide model development.

# %% [markdown]
# ## 1. Load and Explore Data

# %%
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# Load AST data
df = pd.read_csv('../data/ast_data.csv')
print(f"Dataset shape: {df.shape}")
print(f"\nColumns: {df.columns.tolist()}")

# %%
# Basic statistics
print("Species distribution:")
print(df['species'].value_counts().head(10))

# %%
print("\nAntimicrobial distribution:")
print(df['antimicrobial'].value_counts().head(10))

# %%
# Class balance by species and drug
species_drug_counts = df.groupby(['species', 'antimicrobial', 'is_resistant']).size().unstack(fill_value=0)
species_drug_counts.columns = ['susceptible', 'resistant']
species_drug_counts['total'] = species_drug_counts.sum(axis=1)
species_drug_counts['resistance_rate'] = species_drug_counts['resistant'] / species_drug_counts['total']
species_drug_counts = species_drug_counts[species_drug_counts['total'] >= 50].sort_values('total', ascending=False)

species_drug_counts.head(10)

# %%
# Visualize resistance rates
fig, ax = plt.subplots(figsize=(12, 6))
top_pairs = species_drug_counts.head(20)
ax.barh(range(len(top_pairs)), top_pairs['resistance_rate'])
ax.set_yticks(range(len(top_pairs)))
ax.set_yticklabels([f"{row[0]} - {row[1]}" for row in top_pairs.index])
ax.set_xlabel('Resistance Rate')
ax.set_title('Top 20 Species-Drug Pairs by Resistance Rate')
plt.tight_layout()
plt.savefig('../results/resistance_rates.png', dpi=150)

# %% [markdown]
# ## 2. Select Target for Proof-of-Concept

# %%
# Find balanced dataset for PoC
target_species = "Escherichia coli"
target_drug = "Ciprofloxacin"

target_df = df[(df['species'] == target_species) & (df['antimicrobial'] == target_drug)]
print(f"Found {len(target_df)} records for {target_species} - {target_drug}")

print(f"Class distribution: {target_df['is_resistant'].value_counts().to_dict()}")

# Get unique genomes
genomes = target_df['genome_id'].unique()
print(f"Unique genomes: {len(genomes)}")

# %% [markdown]
# ## 3. Prepare for Model Training

# %%
# Save filtered labels for training
target_df.to_csv('../data/target_labels.csv', index=False)
print("Saved target labels to ../data/target_labels.csv")

# %% [markdown]
# ## 4. Summary Statistics for Proposal

# %%
# Generate summary table for proposal
summary_stats = {
    'Total genomes in PATRIC': f"{df['genome_id'].nunique():,}",
    'Total records': f"{len(df):,}",
    'Species': df['species'].nunique(),
    'Antimicrobials': df['antimicrobial'].nunique(),
    'Target species': target_species,
    'Target drug': target_drug,
    'Target samples': len(target_df),
    'Target resistant': target_df['is_resistant'].sum(),
    'Target susceptible': len(target_df) - target_df['is_resistant'].sum(),
}

summary_df = pd.DataFrame(list(summary_stats.items()), columns=['Metric', 'Value'])
print("\nSummary Statistics for Proposal:")
print(summary_df.to_string(index=False))
